{
  "name": "frontend",
  "private": true,
  "version": "1.0.1",
  "type": "module",
  "description": "수식 문서 HWP 자동 변환기",
  "author": "Jeong",
  "scripts": {
    "dev": "vite",
    "deploy": "electron-builder",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "electron": "electron .",
    "electron:dev": "vite & electron .",
    "start": "concurrently \"npm run dev\" \"npm run electron\"",
    "dist": "npm run build && electron-builder"
  },
  "dependencies": {},
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.2",
    "lucide-react": "^0.577.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "@eslint/js": "^9.39.1",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "concurrently": "^9.2.1",
    "electron": "^40.6.1",
    "electron-builder": "^26.8.1",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.48.0",
    "vite": "^7.3.1"
  },
  "build": {
    "appId": "com.hwpit.app",
    "productName": "HWP it!",
    "directories": {
      "output": "../release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "!node_modules/**/*"
    ],
    "extraResources": [
      {
        "from": "../backend/dist/hwp-it-server.exe",
        "to": "."
      }
    ],
    "win": {
      "target": "nsis"
    },
    "electronLanguages": ["ko", "en-US"]
  },
  "main": "electron/main.js",
  "homepage": "./"
}
